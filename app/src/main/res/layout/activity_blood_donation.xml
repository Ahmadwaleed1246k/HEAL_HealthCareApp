<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- App Bar Replacement -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="@color/colorSecondary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:text="Digital Sanctuary"
                android:textColor="@color/colorOnSurface"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <androidx.cardview.widget.CardView
                android:id="@+id/profileCard"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/colorSecondary">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_person"
                    android:layout_gravity="center"
                    app:tint="@color/white" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Hero Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/blood_donation_hero"
                    android:scaleType="centerCrop" />

                <!-- Gradient Overlay for readability -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_blood_gradient_overlay" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_button_light_green"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="Urgent Need: Type O-"
                        android:textColor="#004D40"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="The Gift of\nVitality."
                        android:textColor="@color/white"
                        android:textSize="32sp"
                        android:fontFamily="sans-serif-bold"
                        android:lineSpacingExtra="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Your contribution flows through the heart of our community. Join the Ether Clinical sanctuary in sustaining the life-force of those in need."
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:alpha="0.9" />
                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Live Supply Index Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Live Supply Index"
                    android:textColor="#004D40"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Real-time inventory levels across\nEther networks."
                    android:textColor="@color/colorSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_blood_badge"
                android:text="LIVE\nSYNC"
                android:textColor="#00695C"
                android:textSize="10sp"
                android:fontFamily="sans-serif-bold"
                android:gravity="center" />
        </LinearLayout>

        <!-- Live Supply Grid -->
        <GridLayout
            android:id="@+id/glSupplyIndex"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            android:rowCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">
            <!-- Items added dynamically -->
        </GridLayout>

        <!-- Can I Donate Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gradient_teal"
                android:orientation="vertical"
                android:padding="24dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Can I Donate?"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-bold" />
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Quickly verify your eligibility based on recent health markers, travel, and lifestyle."
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:alpha="0.9" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">
                    
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_checkup" app:tint="#A5D6A7" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Aged 17-65 years old" android:textColor="@color/white" android:textSize="12sp" android:layout_marginStart="8dp" android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                    
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_checkup" app:tint="#A5D6A7" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Weight over 50kg (110lbs)" android:textColor="@color/white" android:textSize="12sp" android:layout_marginStart="8dp" android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                    
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_checkup" app:tint="#A5D6A7" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Good general health &amp; wellness" android:textColor="@color/white" android:textSize="12sp" android:layout_marginStart="8dp" android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>
                
                <TextView
                    android:id="@+id/btnEligibilityCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button_light_green"
                    android:paddingHorizontal="24dp"
                    android:gravity="center"
                    android:text="Start Eligibility Check \u2192"
                    android:textColor="#004D40"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Nearby Centers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:gravity="bottom">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nearby Centers"
                android:textColor="#212121"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show Map View"
                android:textColor="#00897B"
                android:textSize="10sp"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llNearbyCenters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="16dp">
            <!-- Centers populated dynamically -->
        </LinearLayout>

        <!-- Reserve Your Slot -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="Reserve Your Slot"
            android:textColor="#212121"
            android:textSize="18sp"
            android:fontFamily="sans-serif-bold" />
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="4dp"
            android:text="Select a time that aligns with your rhythm. We recommend hydrating well 24 hours prior to your visit."
            android:textColor="@color/colorSecondary"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/btnDateSelector"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_white_rounded"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">
            
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_schedule"
                android:background="@drawable/bg_blood_badge"
                android:padding="6dp"
                app:tint="#00695C" />
                
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NEXT AVAILABLE"
                    android:textColor="#00897B"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-bold" />
                <TextView
                    android:id="@+id/tvSelectedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tomorrow, Oct 14"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </LinearLayout>

        <GridLayout
            android:id="@+id/glTimeSlots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            android:alignmentMode="alignMargins">
            <!-- Time slots added dynamically -->
        </GridLayout>

        <TextView
            android:id="@+id/btnConfirmBooking"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/gradient_teal"
            android:gravity="center"
            android:text="Confirm Donation Booking"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-bold"
            android:textSize="14sp" />

        <!-- Footer Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gradient_teal"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="40dp">
                
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_hospital"
                    app:tint="#A5D6A7" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WELLNESS\nSAFEWORK"
                    android:textColor="#A5D6A7"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:text="PHILOSOPHY"
            android:textColor="#00897B"
            android:textSize="10sp"
            android:fontFamily="sans-serif-bold"
            android:letterSpacing="0.1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            android:text="A Sanctuary for\nCollective\nWellbeing."
            android:textColor="#212121"
            android:textSize="28sp"
            android:fontFamily="sans-serif-bold"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            android:text="&quot;Blood donation is the ultimate expression of human connectivity. In every drop, there is a story of resilience, and in every donor, a silent hero.&quot;"
            android:textColor="@color/colorSecondary"
            android:textSize="14sp"
            android:textStyle="italic" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            android:text="At Ether Clinical, we view donation not as a medical procedure, but as a ritual of restoration. By donating, you replenish the community's health reserves, ensuring that during the most vulnerable moments, no life is left waiting.\n\nBeyond the altruistic impact, donors often experience a renewed sense of purpose and a subtle metabolic reset. It is a win-win for the ecosystem of life."
            android:textColor="@color/colorSecondary"
            android:textSize="12sp"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>
</ScrollView>
