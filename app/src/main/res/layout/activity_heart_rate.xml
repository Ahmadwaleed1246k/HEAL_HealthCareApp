<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7FAF9">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0E6858"
        android:padding="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_back"
                android:padding="8dp"
                android:background="#33FFFFFF"
                app:tint="@color/white"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Heart Rate Monitor"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"/>
        </RelativeLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Camera preview area -->
            <androidx.cardview.widget.CardView
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="90dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A1A1A">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextureView
                        android:id="@+id/textureView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>

                    <!-- Signal quality overlay -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/signalDot"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:background="@drawable/bg_circle"
                            android:backgroundTint="#66FF0000"
                            android:visibility="gone"/>
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Instructions -->
            <TextView
                android:id="@+id/tvInstruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Place your finger over the rear camera"
                android:textSize="15sp"
                android:textColor="#333333"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tvSubInstruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Press gently • Do not move"
                android:textSize="13sp"
                android:textColor="#888888"
                android:gravity="center"/>

            <!-- Signal quality indicator -->
            <LinearLayout
                android:id="@+id/llSignalQuality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#F0F0F0"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:visibility="gone">

                <View
                    android:id="@+id/viewSignalIndicator"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="#FF5722"/>

                <TextView
                    android:id="@+id/tvSignalQuality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Weak signal"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <!-- Progress -->
            <ProgressBar
                android:id="@+id/progressMeasure"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="24dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/bg_progress_heart"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Measuring... 0%"
                android:textSize="13sp"
                android:textColor="#888"
                android:visibility="gone"/>

            <!-- BPM Result -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOUR HEART RATE"
                        android:textSize="11sp"
                        android:textColor="#888"
                        android:fontFamily="sans-serif-bold"
                        android:letterSpacing="0.1"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tvBpm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="64sp"
                            android:textColor="#0E6858"
                            android:fontFamily="sans-serif-black"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="BPM"
                            android:textSize="18sp"
                            android:textColor="#0E6858"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvBpmCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="Normal"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="#2E7D32"
                        android:background="#E8F5E9"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Start/Stop button -->
            <TextView
                android:id="@+id/btnStartMeasure"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_tab_active"
                android:gravity="center"
                android:text="Start Measurement"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"/>

            <!-- Disclaimer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:text="⚠ This app is for wellness purposes only, not medical use. For accurate readings, consult a healthcare professional."
                android:textSize="11sp"
                android:textColor="#999"
                android:gravity="center"
                android:lineSpacingExtra="3dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
